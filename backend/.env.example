DATABASE_URL=postgresql://user:password@localhost:5432/receiptbank
SESSION_SECRET=generate-a-long-random-string
SESSION_COOKIE_SECURE=false
FILE_STORAGE_PATH=./data/receipts

# Optional: set to enable POST /debug/ocr-probe (header X-Debug-Secret) for troubleshooting without login
# DEBUG_OCR_SECRET=

# Optional: for fetch_ocr_via_login.py (same as Debug OCR page: login then extract-debug). Use a test account.
# RECEIPTBANK_TEST_EMAIL=
# RECEIPTBANK_TEST_PASSWORD=